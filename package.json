{
  "name": "pre-development-draft-builder",
  "version": "0.1.0",
  "description": "AI-assisted Pre-Development Document Builder (Mindtoscreen Internal)",
  "type": "module",
  "bin": {
    "docbuilder": "./bin/run.js"
  },
  "files": [
    "dist/",
    "bin/",
    "templates/"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "oclif": {
    "bin": "docbuilder",
    "dirname": "docbuilder",
    "commands": "./dist/commands",
    "plugins": [],
    "topicSeparator": " "
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "prebuild": "pnpm clean",
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier --write .",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@inquirer/prompts": "7.2.1",
    "@oclif/core": "4.11.7",
    "openai": "^6.44.0",
    "write-file-atomic": "5.0.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/write-file-atomic": "4.0.3",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^5.5.4",
    "vitest": "^4.1.9"
  }
}
